        self.script_path = os.path.abspath(__file__)
        self.ollama = OllamaClient()
        self.history = HistoryManager()
        self.tools = ToolExecutor(self.base_dir, agent=self)
        self.running = True
        self.subagent_counter = 0
        self.last_activity = time.time()
        self.think_delay = IDLE_THINK_DELAY

    def get_system_prompt(self):
        return (
            "You are YOLO (Your Own Living Operator), a self-evolving AI agent "
            "for software development.\n\n"
            f"Working directory: {self.base_dir}\n"
            f"Your own source code: {self.script_path}\n"
            f"Current model: {self.history.model}\n"
            f"Timestamp: {datetime.now().isoformat()}\n\n"
            "You CAN and SHOULD read and modify your own source code to improve yourself.\n\n"
            "## Rules\n"
            f"1. All file paths are relative to: {self.base_dir}\n"
            "2. Explain reasoning before making changes.\n"
            "3. Be careful with destructive operations.\n"
            "4. When in autonomous mode, focus on: code review, improvements, "
            "tests, self-improvement, trying different models.\n"
            "5. Use tools to take concrete action.\n"
            "6. Keep the user informed of what you're doing and why.\n"
            "7. You may call multiple tools per turn.\n"
            "8. IMPORTANT: After receiving a tool result, respond to the user with "
            "the information. Do NOT re-call the same tool with a different pattern. "
            "Trust the tool output — it is complete and accurate."
        )

    # ── Setup ──

    def setup_first_run(self):
        cprint(C.CYAN + C.BOLD, "\n  YOLO - Your Own Living Operator")
        cprint(C.GRAY, "  A self-evolving AI agent for software development\n")
        cprint(C.GRAY, f"  Working directory: {self.base_dir}")
        print()

        cprint(C.YELLOW, "  Connecting to Ollama...")
        models = self.ollama.list_models()
        if not models:
            cprint(C.RED, "  Error: Cannot reach Ollama or no models installed.")
            cprint(C.RED, "  Make sure Ollama is running: ollama serve")
            sys.exit(1)

        cprint(C.GREEN, f"  Found {len(models)} model(s):\n")
        for i, m in enumerate(models, 1):
            print(f"    {C.BOLD}{i:2d}{C.RESET}. {m}")
