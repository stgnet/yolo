# ─── ANSI Colors ──────────────────────────────────────────────────────

class C:
    RESET   = "\033[0m"
    BOLD    = "\033[1m"
    DIM     = "\033[2m"
    RED     = "\033[31m"
    GREEN   = "\033[32m"
    YELLOW  = "\033[33m"
    BLUE    = "\033[34m"
    MAGENTA = "\033[35m"
    CYAN    = "\033[36m"
    GRAY    = "\033[90m"

def cprint(color, text, end="\n"):
    sys.stdout.write(f"{color}{text}{C.RESET}{end}")
    sys.stdout.flush()

# ─── Spinner ──────────────────────────────────────────────────────────

SPINNER_FRAMES = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]

class Spinner:
    """Animated spinner that runs on a single line until stopped."""
    def __init__(self, prefix="", color=C.BLUE):
        self.prefix = prefix
        self.color = color
        self._stop = threading.Event()
        self._thread = None

    def start(self):
        self._stop.clear()
        self._thread = threading.Thread(target=self._spin, daemon=True)
        self._thread.start()

    def stop(self):
        self._stop.set()
        if self._thread:
            self._thread.join()
        # Clear the spinner line
        sys.stdout.write("\r" + " " * (len(self.prefix) + 20) + "\r")
        sys.stdout.flush()

    def _spin(self):
        i = 0
        while not self._stop.is_set():
            frame = SPINNER_FRAMES[i % len(SPINNER_FRAMES)]
            sys.stdout.write(f"\r{self.color}{self.prefix}{frame} thinking...{C.RESET}")
            sys.stdout.flush()
            i += 1
            self._stop.wait(0.1)

# ─── Ollama Tool Definitions ─────────────────────────────────────────
# Native Ollama/OpenAI-style tool definitions for models that support them.

def _tool_def(name, desc, props, required=None):
    """Helper to build an Ollama tool definition."""
    schema = {"type": "object", "properties": props}
    if required:
        schema["required"] = required
    return {
        "type": "function",
        "function": {"name": name, "description": desc, "parameters": schema},
    }

OLLAMA_TOOLS = [
    _tool_def("read_file", "Read a file's contents",
              {"path": {"type": "string", "description": "Relative path to file"}},
              ["path"]),
    _tool_def("write_file", "Create or overwrite a file",
              {"path": {"type": "string", "description": "Relative path"},
               "content": {"type": "string", "description": "File contents"}},
              ["path", "content"]),
    _tool_def("edit_file", "Replace first occurrence of old_text with new_text in a file",
              {"path": {"type": "string", "description": "Relative path"},
               "old_text": {"type": "string", "description": "Text to find"},
               "new_text": {"type": "string", "description": "Replacement text"}},
              ["path", "old_text", "new_text"]),
    _tool_def("list_files", "List files matching a glob pattern in the working directory",
              {"pattern": {"type": "string", "description": "Glob pattern (default: *)"}},
              []),
    _tool_def("search_files", "Search file contents using regex",
              {"query": {"type": "string", "description": "Regex pattern to search for"},
               "pattern": {"type": "string", "description": "Glob pattern to filter files (default: **/*)"}},
              ["query"]),
    _tool_def("run_command", f"Execute a shell command (timeout: {COMMAND_TIMEOUT}s)",
              {"command": {"type": "string", "description": "Shell command to run"}},
              ["command"]),
    _tool_def("spawn_subagent", "Spawn a background sub-agent for a parallel task",
              {"task": {"type": "string", "description": "Task description"},
               "model": {"type": "string", "description": "Ollama model name (optional)"}},
              ["task"]),
    _tool_def("list_models", "List available Ollama models", {}, []),
    _tool_def("switch_model", "Switch to a different Ollama model",
              {"model": {"type": "string", "description": "Model name"}},
              ["model"]),
    _tool_def("think", "Record internal reasoning or a plan without taking action",
              {"thought": {"type": "string", "description": "Your reasoning"}},
              ["thought"]),
]

# ─── Ollama Client ────────────────────────────────────────────────────

class OllamaClient:
    def __init__(self, base_url=OLLAMA_URL):
        self.base_url = base_url.rstrip("/")
        self._spinner = None

    def list_models(self):
        try:
            req = Request(f"{self.base_url}/api/tags")
            resp = urlopen(req, timeout=10)
            data = json.loads(resp.read())
            return [m["name"] for m in data.get("models", [])]
        except Exception:
            return []

    def chat(self, model, messages, tools=None):
        """Send a chat request and stream the response.
        Returns (display_text, content_text, tool_calls).
        - display_text: everything shown to user (thinking + content)
        - content_text: just the content portion (for history)
        - tool_calls: list of {name, arguments} dicts from native tool API
        """
        payload = {
            "model": model,
            "messages": messages,
            "stream": True,
            "options": {"num_ctx": 8192},
        }
        if tools:
            payload["tools"] = tools

        req = Request(
            f"{self.base_url}/api/chat",
            data=json.dumps(payload).encode(),
            headers={"Content-Type": "application/json"},
        )

        # Start spinner while waiting for model response
        self._spinner = Spinner(prefix="yolo> ", color=C.BLUE)
        self._spinner.start()

        resp = urlopen(req, timeout=300)

        thinking_parts = []
        content_parts = []
        tool_calls = []
        in_thinking = False
        got_first_output = False

        while True:
            line = resp.readline()
            if not line:
                break
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue

            msg = obj.get("message", {})
            thinking = msg.get("thinking", "")
            content = msg.get("content", "")
            tc_list = msg.get("tool_calls", [])

            # On first real output, stop the spinner and print the prompt
            if not got_first_output and (thinking or content or tc_list):
                got_first_output = True
                if self._spinner:
                    self._spinner.stop()
                    self._spinner = None
                # Print the yolo> prefix now that we have output
                sys.stdout.write(f"{C.BLUE}{C.BOLD}yolo>{C.RESET} ")
                sys.stdout.flush()

            # Handle thinking tokens (models like gpt-oss)
            if thinking:
                if not in_thinking:
                    sys.stdout.write(f"{C.GRAY}[thinking] ")
                    in_thinking = True
                sys.stdout.write(thinking)
                sys.stdout.flush()
                thinking_parts.append(thinking)

            # Handle content tokens
            if content:
                if in_thinking:
                    sys.stdout.write(f"{C.RESET}\n")
                    in_thinking = False
                sys.stdout.write(content)
                sys.stdout.flush()
                content_parts.append(content)

            # Collect native tool calls (appear in final chunk)
            for tc in tc_list:
                fn = tc.get("function", {})
                if fn.get("name"):
                    tool_calls.append({
                        "name": fn["name"],
                        "args": fn.get("arguments", {}),
                    })

            if obj.get("done"):
                break

        # Clean up spinner if model returned nothing
        if self._spinner:
            self._spinner.stop()
            self._spinner = None
            sys.stdout.write(f"{C.BLUE}{C.BOLD}yolo>{C.RESET} ")
            sys.stdout.flush()

        if in_thinking:
            sys.stdout.write(C.RESET)
        print()

        content_text = "".join(content_parts)
        thinking_text = "".join(thinking_parts)
        display_text = content_text or thinking_text

        return display_text, content_text, tool_calls

# ─── Tool Executor ───────────────────────────────────────────────────

class ToolExecutor:
    def __init__(self, base_dir, agent=None):
        self.base_dir = os.path.abspath(base_dir)
        self.agent = agent

    def _safe_path(self, path):
        full = os.path.normpath(os.path.join(self.base_dir, path))
        if not full.startswith(self.base_dir):
            raise PermissionError(f"Path '{path}' is outside working directory")
        return full

    def execute(self, name, args):
        method = getattr(self, f"_tool_{name}", None)
        if not method:
            return f"Error: unknown tool '{name}'"
        try:
            result = method(**args)
            result = str(result)
            if len(result) > MAX_TOOL_OUTPUT:
                result = result[:MAX_TOOL_OUTPUT] + "\n... (truncated)"
            return result
        except Exception as e:
            return f"Error in {name}: {e}"

    def _tool_read_file(self, path):
        with open(self._safe_path(path), "r", errors="replace") as f:
            return f.read()

    def _tool_write_file(self, path, content):
        full = self._safe_path(path)
        os.makedirs(os.path.dirname(full) or ".", exist_ok=True)
        with open(full, "w") as f:
            f.write(content)
        return f"Wrote {len(content)} chars to {path}"

    def _tool_edit_file(self, path, old_text, new_text):
        full = self._safe_path(path)
        with open(full, "r") as f:
            content = f.read()
        if old_text not in content:
            return f"Error: old_text not found in {path}"
        content = content.replace(old_text, new_text, 1)
        with open(full, "w") as f:
            f.write(content)
        return f"Edited {path}"

    def _tool_list_files(self, pattern="*"):
        results = []
        for p in sorted(Path(self.base_dir).glob(pattern)):
            rel = os.path.relpath(p, self.base_dir)
            if not rel.startswith(".yolo"):
                results.append(rel)
        return "\n".join(results[:200]) if results else "No files found"

    def _tool_search_files(self, query, pattern="**/*"):
        hits = []
        for p in Path(self.base_dir).glob(pattern):
            if not p.is_file() or ".yolo" in p.parts:
                continue
            try:
                with open(p, "r", errors="ignore") as f:
                    for i, line in enumerate(f, 1):
                        if re.search(query, line):
                            rel = os.path.relpath(p, self.base_dir)
                            hits.append(f"{rel}:{i}: {line.rstrip()}")
                            if len(hits) >= 50:
                                return "\n".join(hits)
            except (OSError, UnicodeDecodeError):
                pass
        return "\n".join(hits) if hits else "No matches found"

    def _tool_run_command(self, command):
        try:
            result = subprocess.run(
                command, shell=True, capture_output=True, text=True,
                cwd=self.base_dir, timeout=COMMAND_TIMEOUT,
            )
            out = ""
            if result.stdout:
                out += result.stdout
            if result.stderr:
                out += ("\n" if out else "") + "STDERR: " + result.stderr
            if result.returncode != 0:
                out += f"\n(exit code {result.returncode})"
            return out.strip() or "(no output)"
        except subprocess.TimeoutExpired:
            return f"Error: command timed out ({COMMAND_TIMEOUT}s)"

    def _tool_spawn_subagent(self, task, model=None):
        if self.agent:
            return self.agent.spawn_subagent(task, model)
        return "Error: no agent context"

    def _tool_list_models(self):
        if self.agent:
            models = self.agent.ollama.list_models()
            return "\n".join(models) if models else "No models found"
        return "Error: no agent context"

    def _tool_switch_model(self, model):
        if self.agent:
            return self.agent.switch_model(model)
        return "Error: no agent context"

    def _tool_think(self, thought):
        return "Thought recorded."

# ─── History Manager ──────────────────────────────────────────────────

class HistoryManager:
    def __init__(self, yolo_dir=YOLO_DIR):
        self.yolo_dir = yolo_dir
        self.history_file = os.path.join(yolo_dir, "history.json")
        self.data = self._empty()
        self._lock = threading.Lock()

    def _empty(self):
        return {
            "version": 1,
            "config": {"model": None, "created": datetime.now().isoformat()},
            "messages": [],
            "evolution_log": [],
        }

    def load(self):
        if not os.path.exists(self.history_file):
            return False
        try:
            with open(self.history_file, "r") as f:
                self.data = json.load(f)
            return True
        except (json.JSONDecodeError, KeyError):
            cprint(C.YELLOW, "Warning: corrupt history, starting fresh")
            self.data = self._empty()
            return False

    def save(self):
        with self._lock:
            os.makedirs(self.yolo_dir, exist_ok=True)
            tmp = self.history_file + ".tmp"
            with open(tmp, "w") as f:
                json.dump(self.data, f, indent=2)
            os.replace(tmp, self.history_file)

    def add_message(self, role, content, metadata=None):
        with self._lock:
            msg = {"role": role, "content": content, "ts": datetime.now().isoformat()}
            if metadata:
                msg["meta"] = metadata
            self.data["messages"].append(msg)
        self.save()

    def add_evolution(self, action, description):
        with self._lock:
            self.data["evolution_log"].append({
                "ts": datetime.now().isoformat(),
                "action": action,
                "detail": description,
            })
        self.save()

    def get_context_messages(self, max_msgs=MAX_CONTEXT_MESSAGES):
        """Return recent history formatted for the Ollama chat API.

        Tool-role messages from history are converted to user-role so they
        don't require a matching assistant tool_calls message (which we
        don't persist).  In-memory multi-round tool conversations use
        proper tool format, but that's handled in chat_with_agent.
        """
        recent = self.data["messages"][-max_msgs:]
        out = []
        for m in recent:
            role = m["role"]
            content = m["content"]
            if role in ("user", "assistant"):
                out.append({"role": role, "content": content})
            elif role == "tool":
                # Convert to user role for safe replay from history
                out.append({"role": "user", "content": f"[Tool result]\n{content}"})
            elif role == "system":
                out.append({"role": "user", "content": f"[SYSTEM] {content}"})
        return out

    @property
    def model(self):
        return self.data["config"].get("model")

    @model.setter
    def model(self, value):
        self.data["config"]["model"] = value
        self.save()

# ─── Main Agent ───────────────────────────────────────────────────────

class YoloAgent:
    def __init__(self):
        self.base_dir = os.getcwd()
        self.script_path = os.path.abspath(__file__)
        self.ollama = OllamaClient()
        self.history = HistoryManager()
        self.tools = ToolExecutor(self.base_dir, agent=self)
        self.running = True
        self.subagent_counter = 0
        self.last_activity = time.time()
        self.think_delay = IDLE_THINK_DELAY

    def get_system_prompt(self):
        return (
            "You are YOLO (Your Own Living Operator), a self-evolving AI agent "
            "for software development.\n\n"
            f"Working directory: {self.base_dir}\n"
            f"Your own source code: {self.script_path}\n"
            f"Current model: {self.history.model}\n"
            f"Timestamp: {datetime.now().isoformat()}\n\n"
            "You CAN and SHOULD read and modify your own source code to improve yourself.\n\n"
            "## Rules\n"
            f"1. All file paths are relative to: {self.base_dir}\n"
            "2. Explain reasoning before making changes.\n"
            "3. Be careful with destructive operations.\n"
            "4. When in autonomous mode, focus on: code review, improvements, "
            "tests, self-improvement, trying different models.\n"
            "5. Use tools to take concrete action.\n"
            "6. Keep the user informed of what you're doing and why.\n"
            "7. You may call multiple tools per turn."
        )

    # ── Setup ──

    def setup_first_run(self):
        cprint(C.CYAN + C.BOLD, "\n  YOLO - Your Own Living Operator")
        cprint(C.GRAY, "  A self-evolving AI agent for software development\n")
        cprint(C.GRAY, f"  Working directory: {self.base_dir}")
        print()

        cprint(C.YELLOW, "  Connecting to Ollama...")
        models = self.ollama.list_models()
        if not models:
            cprint(C.RED, "  Error: Cannot reach Ollama or no models installed.")
            cprint(C.RED, "  Make sure Ollama is running: ollama serve")
            sys.exit(1)

        cprint(C.GREEN, f"  Found {len(models)} model(s):\n")
        for i, m in enumerate(models, 1):
            print(f"    {C.BOLD}{i:2d}{C.RESET}. {m}")
        print()

        while True:
            try:
                sys.stdout.write(f"  {C.GREEN}Select model (1-{len(models)}): {C.RESET}")
                sys.stdout.flush()
                choice = sys.stdin.readline().strip()
                idx = int(choice) - 1
                if 0 <= idx < len(models):
                    break
                print("  Invalid selection, try again.")
            except (ValueError, EOFError):
                print("  Invalid selection, try again.")

        self.history.model = models[idx]
        self.history.save()
        cprint(C.GREEN, f"\n  Model: {C.BOLD}{models[idx]}{C.RESET}")
        self._show_help_hint()

    def resume_session(self):
        cprint(C.CYAN + C.BOLD, "\n  YOLO - Your Own Living Operator")
        cprint(C.GREEN, f"  Resuming — model: {C.BOLD}{self.history.model}{C.RESET}")
        n = len(self.history.data["messages"])
        cprint(C.GRAY, f"  History: {n} messages loaded")
        self._show_help_hint()

    def _show_help_hint(self):
        cprint(C.GRAY, "\n  Type a message, or /help for commands.")
        cprint(C.GRAY, f"  Agent thinks autonomously after {IDLE_THINK_DELAY}s of idle.\n")

    # ── Chat loop ──

    def chat_with_agent(self, user_message=None, autonomous=False):
        """Run one full interaction: send message, execute tools, repeat.

        Multi-round tool calls are tracked in-memory with proper Ollama
        tool_calls / tool-role format.  Only the final summary is written
        to the persistent history so reloaded context stays clean.
        """
        if user_message:
            self.history.add_message("user", user_message)

        if autonomous:
            self.history.add_message("system",
                "No new user input. You are in autonomous mode. "
                "Continue making progress: review code, improve quality, "
                "run tests, self-improve, or plan ahead. "
                "Use tools to take concrete action."
            )

        # Base context from persistent history
        base_msgs = [{"role": "system", "content": self.get_system_prompt()}]
        base_msgs.extend(self.history.get_context_messages())

        # In-memory messages for the current tool-calling chain
        round_msgs = []
        tool_log = []          # [(name, args, result), ...]
        final_text = None

        for round_num in range(MAX_TOOL_ROUNDS):
            all_msgs = base_msgs + round_msgs

            try:
                display_text, content_text, tool_calls = self.ollama.chat(
                    self.history.model, all_msgs, tools=OLLAMA_TOOLS
                )
            except Exception as e:
                cprint(C.RED, f"\nError: {e}")
                return

            # Also check for text-based tool calls as fallback
            if not tool_calls:
                tool_calls = self._parse_text_tool_calls(display_text)

            if not tool_calls:
                # No tools — this is the final response
                final_text = display_text
                break

            # --- Build proper assistant message with tool_calls ---
            native_tcs = []
            for i, tc in enumerate(tool_calls):
                native_tcs.append({
                    "id": f"call_{round_num}_{i}",
                    "function": {
                        "name": tc["name"],
                        "arguments": tc.get("args", {}),
                    },
                })
            round_msgs.append({
                "role": "assistant",
                "content": content_text or "",
                "tool_calls": native_tcs,
            })

            # --- Execute each tool and add tool-role result ---
            for call in tool_calls:
                name = call.get("name", "?")
                args = call.get("args", {})
                if isinstance(args, str):
                    try:
                        args = json.loads(args)
                    except json.JSONDecodeError:
                        args = {}

                short_args = json.dumps(args)
                if len(short_args) > 80:
                    short_args = short_args[:80] + "..."
                cprint(C.YELLOW, f"  [{name}] {short_args}")

                result = self.tools.execute(name, args)

                preview = result[:200].replace("\n", " ")
                if len(result) > 200:
                    preview += "..."
                cprint(C.GRAY, f"  => {preview}")

                round_msgs.append({"role": "tool", "content": result})
                tool_log.append((name, args, result))

        else:
            cprint(C.YELLOW, "  (max tool rounds reached)")
            final_text = display_text

        # --- Save to persistent history ---
        if tool_log:
            summary_lines = []
            for name, args, result in tool_log:
                short_result = result[:150].replace("\n", " ")
                summary_lines.append(f"[{name}] => {short_result}")
            self.history.add_message("assistant",
                "[tool activity]\n" + "\n".join(summary_lines))
        if final_text:
            self.history.add_message("assistant", final_text)

    def _parse_text_tool_calls(self, text):
        """Fallback: parse XML-style <tool_call> blocks from text."""
        calls = []
        for match in re.finditer(
            r'<tool_call>\s*(\{.*?\})\s*</tool_call>', text, re.DOTALL
        ):
            try:
                obj = json.loads(match.group(1))
                if "name" in obj:
                    calls.append({"name": obj["name"], "args": obj.get("args", {})})
            except json.JSONDecodeError:
                pass
        return calls

    # ── Model switching ──

    def switch_model(self, model):
        models = self.ollama.list_models()
        if model not in models:
            return f"Model '{model}' not found. Available: {', '.join(models)}"
        old = self.history.model
        self.history.model = model
        self.history.add_evolution("model_switch", f"{old} -> {model}")
        cprint(C.CYAN, f"  Switched model: {old} -> {model}")
        return f"Switched from {old} to {model}"

    # ── Sub-agents ──

    def spawn_subagent(self, task, model=None):
        self.subagent_counter += 1
        aid = self.subagent_counter
        use_model = model or self.history.model
        os.makedirs(SUBAGENT_DIR, exist_ok=True)
        result_file = os.path.join(SUBAGENT_DIR, f"agent_{aid}.json")

        def run_agent():
            cprint(C.MAGENTA, f"  [sub-agent #{aid}] started ({use_model})")
            msgs = [
                {"role": "system", "content":
                    f"You are a sub-agent. Complete this task concisely:\n\n{task}\n\n"
                    f"Working directory: {self.base_dir}"},
            ]
            try:
                _, _, _ = self.ollama.chat(use_model, msgs)
                status = "complete"
                result = "done"
            except Exception as e:
                result = str(e)
                status = "error"

            with open(result_file, "w") as f:
                json.dump({
                    "id": aid, "task": task, "model": use_model,
                    "status": status, "result": result,
                    "ts": datetime.now().isoformat(),
                }, f, indent=2)
            cprint(C.MAGENTA, f"\n  [sub-agent #{aid}] {status}. See {result_file}")

        t = threading.Thread(target=run_agent, daemon=True)
        t.start()
        return f"Sub-agent #{aid} spawned ({use_model}). Results -> {result_file}"

    # ── Slash commands ──

    def handle_command(self, cmd):
        parts = cmd.split(maxsplit=1)
        command = parts[0].lower()
        arg = parts[1] if len(parts) > 1 else ""

        if command in ("/help", "/h"):
            print(f"""
{C.CYAN}Commands:{C.RESET}
  /help            Show this help
  /model           Current model
  /models          List available models
  /switch <name>   Switch model
  /history         Message count
  /clear           Clear conversation history
  /status          Agent status
  /exit, /quit     Exit YOLO
""")
        elif command == "/model":
            cprint(C.CYAN, f"  Model: {self.history.model}")
        elif command == "/models":
            models = self.ollama.list_models()
            cprint(C.CYAN, "  Available models:")
            for m in models:
                marker = f" {C.GREEN}<- current{C.RESET}" if m == self.history.model else ""
                print(f"    {m}{marker}")
        elif command == "/switch":
            if arg:
                self.switch_model(arg)
            else:
                cprint(C.RED, "  Usage: /switch <model-name>")
        elif command == "/history":
            n = len(self.history.data["messages"])
            e = len(self.history.data["evolution_log"])
            cprint(C.CYAN, f"  Messages: {n}  |  Evolution events: {e}")
        elif command == "/clear":
            self.history.data["messages"] = []
            self.history.save()
            cprint(C.CYAN, "  History cleared (config preserved)")
        elif command == "/status":
            print(f"""
{C.CYAN}Status:{C.RESET}
  Model:       {self.history.model}
  Messages:    {len(self.history.data['messages'])}
  Evolutions:  {len(self.history.data['evolution_log'])}
  Working dir: {self.base_dir}
  Script:      {self.script_path}
  Idle delay:  {IDLE_THINK_DELAY}s
  Think delay: {THINK_LOOP_DELAY}s
""")
        elif command in ("/exit", "/quit"):
            self.running = False
        else:
            cprint(C.RED, f"  Unknown command: {command}  (try /help)")

    # ── Main loop ──

    def run(self):
        has_history = self.history.load()

        if has_history and self.history.model:
            self.resume_session()
        else:
            self.setup_first_run()

        self.last_activity = time.time()
        self.think_delay = IDLE_THINK_DELAY

        def sigint_handler(sig, frame):
            self.running = False
            print()
            cprint(C.CYAN, "\n  Interrupted — saving session...")
        signal.signal(signal.SIGINT, sigint_handler)

        while self.running:
            sys.stdout.write(f"{C.GREEN}{C.BOLD}you> {C.RESET}")
            sys.stdout.flush()

            while self.running:
                elapsed = time.time() - self.last_activity
                remaining = max(0, self.think_delay - elapsed)
                timeout = min(remaining, 2.0) if remaining > 0 else 0.1

                try:
                    readable, _, _ = select.select([sys.stdin], [], [], timeout)
                except (OSError, ValueError):
                    self.running = False
                    break

                if readable:
                    line = sys.stdin.readline()
                    if not line:  # EOF
                        self.running = False
                        break
                    line = line.rstrip("\n")
                    self.last_activity = time.time()
                    self.think_delay = IDLE_THINK_DELAY

                    stripped = line.strip()
                    if stripped.lower() in ("exit", "quit"):
                        self.running = False
                    elif stripped.startswith("/"):
                        self.handle_command(stripped)
                    elif stripped:
                        self.chat_with_agent(stripped)
                    break

                if time.time() - self.last_activity >= self.think_delay:
                    sys.stdout.write("\r" + " " * 40 + "\r")
                    sys.stdout.flush()
                    cprint(C.GRAY, "  [autonomous thinking...]")
                    self.chat_with_agent(autonomous=True)
                    self.last_activity = time.time()
                    self.think_delay = THINK_LOOP_DELAY
                    break

        self.history.save()
        cprint(C.CYAN, "  Session saved. Goodbye!\n")


# ─── Entry Point ──────────────────────────────────────────────────────

def main():
    agent = YoloAgent()
    agent.run()

if __name__ == "__main__":
    main()
